<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
    <title>Create Account | Join Our Blog</title>
    <style>
        body {
            background: radial-gradient(circle at top right, color-mix(in srgb, var(--brand) 20%, transparent), transparent 50%), var(--bg-main);
            min-height: 100vh;
            color: var(--text-main);
        }

        .auth-card {
            background: color-mix(in srgb, var(--bg-surface) 92%, transparent);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 15px 35px var(--shadow-color);
            padding: 40px;
            margin-top: 60px;
            max-width: 500px;
            border: 1px solid var(--border-color);
        }

        .auth-title {
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 5px;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .form-control {
            border-radius: 12px;
            padding: 12px;
            border: 1px solid var(--border-color);
            transition: all 0.3s ease;
            background: var(--bg-subtle);
            color: var(--text-main);
        }

        .form-control:focus {
            box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand) 25%, transparent);
            border-color: var(--brand);
        }

        .btn-signup {
            background: var(--brand);
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 700;
            width: 100%;
            margin-top: 20px;
            transition: transform 0.2s, background 0.3s;
        }

        .btn-signup:hover {
            background: var(--brand-hover);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px var(--shadow-color);
        }

        .login-link {
            text-decoration: none;
            color: var(--brand);
            font-weight: 600;
        }
    </style>
</head>

<body>
    <%- include('./partials/nav') %>

    <div class="container d-flex justify-content-center">
        <div class="auth-card w-100">
            <div class="text-center mb-4">
                <h2 class="auth-title">Join Us</h2>
                <p class="text-muted">Start your blogging journey today</p>
            </div>

            <form action="/user/signup" method="post">
                <div class="mb-3">
                    <label for="fullName" class="form-label">Full Name</label>
                    <input type="text" name="fullName" class="form-control" id="fullName" 
                           placeholder="John Doe" required />
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" id="email" 
                           placeholder="name@example.com" required />
                    <div class="form-text small text-muted">We promise not to spam you.</div>
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label">Create Password</label>
                    <input name="password" type="password" class="form-control" id="password" 
                           placeholder="At least 6 characters" required />
                </div>

                <button type="submit" class="btn btn-primary btn-signup">Create Account</button>
                
                <div class="mt-4 text-center">
                    <p class="small text-muted">
                        Already have an account? <a href="/user/signin" class="login-link">Sign In</a>
                    </p>
                </div>
            </form>
        </div>
    </div>

    <%- include('./partials/scripts') %>
</body>

</html>
