<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>Blogify | Feed</title>
  <style>
    .feed-shell {
      max-width: 1200px;
      margin: 32px auto;
    }

    .panel {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: 18px;
      box-shadow: 0 8px 20px var(--shadow-color);
    }

    .hero-title {
      font-size: clamp(1.7rem, 3.5vw, 2.4rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 6px;
    }

    .search-input,
    .search-select {
      background: var(--bg-subtle);
      border: 1px solid var(--border-color);
      color: var(--text-main);
    }

    .search-input:focus,
    .search-select:focus {
      border-color: var(--brand);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand) 22%, transparent);
    }

    .category-row {
      display: flex;
      flex-wrap: nowrap;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 6px;
    }

    .category-chip {
      border: 1px solid var(--border-color);
      color: var(--text-muted);
      background: var(--bg-surface);
      border-radius: 999px;
      padding: 0.35rem 0.9rem;
      text-decoration: none;
      font-size: 0.82rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .category-chip.active {
      background: var(--brand);
      color: #fff;
      border-color: var(--brand);
    }

    .feed-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: 18px;
      padding: 18px;
      margin-bottom: 14px;
      transition: transform 0.2s ease;
    }

    .feed-card:hover {
      transform: translateY(-3px);
    }

    .feed-cover {
      width: 100%;
      max-height: 320px;
      object-fit: cover;
      border-radius: 14px;
      border: 1px solid var(--border-color);
      margin-top: 12px;
      margin-bottom: 14px;
    }

    .meta-pill {
      border: 1px solid var(--border-color);
      border-radius: 999px;
      padding: 0.25rem 0.65rem;
      font-size: 0.74rem;
      font-weight: 700;
      color: var(--text-muted);
      background: var(--bg-subtle);
    }

    .user-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border-color);
    }

    .user-row:last-child {
      border-bottom: 0;
    }

    .trending-item {
      padding: 10px 0;
      border-bottom: 1px solid var(--border-color);
    }

    .trending-item:last-child {
      border-bottom: 0;
    }
  </style>
</head>
<body>
  <%- include('./partials/nav') %>

  <main class="container-fluid px-3 px-lg-4">
    <div class="feed-shell">
      <div class="row g-4">
        <section class="col-lg-8">
          <div class="panel p-4 mb-3">
            <h1 class="hero-title">Home feed, now social and searchable</h1>
            <p class="theme-text-muted mb-3">Search users/blogs, follow creators, and browse by category.</p>

            <form method="get" action="/" class="row g-2 align-items-center mb-3">
              <div class="col-md-7">
                <input name="q" value="<%= searchQuery %>" type="text" class="form-control search-input" placeholder="Search users or blogs...">
              </div>
              <div class="col-md-3">
                <select name="type" class="form-select search-select">
                  <option value="all" <%= searchType === 'all' ? 'selected' : '' %>>All</option>
                  <option value="users" <%= searchType === 'users' ? 'selected' : '' %>>Users</option>
                  <option value="blogs" <%= searchType === 'blogs' ? 'selected' : '' %>>Blogs</option>
                </select>
              </div>
              <div class="col-md-2 d-grid">
                <button class="btn btn-brand" type="submit">Search</button>
              </div>
              <% if (selectedCategory !== 'All') { %>
                <input type="hidden" name="category" value="<%= selectedCategory %>">
              <% } %>
            </form>

            <div class="category-row">
              <% categories.forEach((category) => { %>
                <% const link = `/?category=${encodeURIComponent(category)}${searchQuery ? `&q=${encodeURIComponent(searchQuery)}` : ''}${searchType !== 'all' ? `&type=${encodeURIComponent(searchType)}` : ''}`; %>
                <a href="<%= link %>" class="category-chip <%= selectedCategory === category ? 'active' : '' %>"><%= category %></a>
              <% }) %>
            </div>
          </div>

          <% if (searchQuery && (searchType === 'all' || searchType === 'users')) { %>
            <div class="panel p-4 mb-3">
              <h5 class="fw-bold mb-3">User results for "<%= searchQuery %>"</h5>
              <% if (userResults.length > 0) { %>
                <% userResults.forEach((person) => { %>
                  <div class="user-row">
                    <a href="/user/profile/<%= person._id %>" class="text-decoration-none d-flex align-items-center gap-2">
                      <img src="<%= person.profileImageURL || '/images/default.jpg' %>" width="40" height="40" class="rounded-circle border" alt="">
                      <div>
                        <div class="fw-semibold" style="color: var(--text-main);"><%= person.fullName %></div>
                        <div class="small theme-text-muted"><%= person.email %></div>
                      </div>
                    </a>
                    <% if (locals.user) { %>
                      <% const userIsFollowed = currentUserFollowingIds.includes(String(person._id)); %>
                      <form method="post" action="/user/<%= person._id %>/follow" class="m-0">
                        <input type="hidden" name="redirectTo" value="<%= currentPath %>">
                        <button class="btn btn-sm <%= userIsFollowed ? 'btn-outline-secondary' : 'btn-brand' %>" type="submit">
                          <%= userIsFollowed ? 'Following' : 'Follow' %>
                        </button>
                      </form>
                    <% } %>
                  </div>
                <% }) %>
              <% } else { %>
                <p class="theme-text-muted mb-0">No users found.</p>
              <% } %>
            </div>
          <% } %>

          <% if (latestBlog) { %>
            <article class="feed-card">
              <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <a href="/user/profile/<%= latestBlog.createdBy?._id || '' %>" class="text-decoration-none d-flex align-items-center gap-2">
                  <img src="<%= latestBlog.createdBy?.profileImageURL || '/images/default.jpg' %>" class="rounded-circle border" width="36" height="36" alt="">
                  <div>
                    <div class="fw-semibold" style="color: var(--text-main);"><%= latestBlog.createdBy?.fullName || 'Unknown' %></div>
                    <div class="small theme-text-muted">Latest post</div>
                  </div>
                </a>
                <div class="d-flex gap-2 flex-wrap">
                  <span class="meta-pill"><%= latestBlog.category || 'Others' %></span>
                  <span class="meta-pill">Likes <%= latestBlog.likesCount || 0 %></span>
                </div>
              </div>

              <h4 class="fw-bold mt-3"><%= latestBlog.title %></h4>
              <p class="theme-text-muted mb-2"><%= latestBlog.body?.substring(0, 170) %>...</p>
              <img src="<%= latestBlog.coverImageURL || '/images/default.jpg' %>" class="feed-cover" alt="">

              <div class="d-flex gap-2">
                <a class="btn btn-brand btn-sm" href="/blog/<%= latestBlog._id %>">Read</a>
                <% if (locals.user && String(latestBlog.createdBy?._id) === String(user._id)) { %>
                  <form action="/blog/<%= latestBlog._id %>/delete" method="post" onsubmit="return confirm('Delete this blog?');">
                    <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                  </form>
                <% } %>
              </div>
            </article>
          <% } %>

          <% const feedBlogs = latestBlog ? blogs.slice(1) : blogs; %>
          <% if (feedBlogs.length > 0) { %>
            <% feedBlogs.forEach((blog) => { %>
              <article class="feed-card">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                  <a href="/user/profile/<%= blog.createdBy?._id || '' %>" class="text-decoration-none d-flex align-items-center gap-2">
                    <img src="<%= blog.createdBy?.profileImageURL || '/images/default.jpg' %>" class="rounded-circle border" width="34" height="34" alt="">
                    <div>
                      <div class="fw-semibold" style="color: var(--text-main);"><%= blog.createdBy?.fullName || 'Unknown' %></div>
                      <div class="small theme-text-muted"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
                    </div>
                  </a>
                  <div class="d-flex gap-2 flex-wrap">
                    <span class="meta-pill"><%= blog.category || 'Others' %></span>
                    <span class="meta-pill">Likes <%= blog.likesCount || 0 %></span>
                  </div>
                </div>

                <h5 class="fw-bold mt-3"><%= blog.title %></h5>
                <p class="theme-text-muted"><%= blog.body?.substring(0, 140) %>...</p>
                <img src="<%= blog.coverImageURL || '/images/default.jpg' %>" class="feed-cover" alt="">

                <div class="d-flex gap-2">
                  <a class="btn btn-outline-primary btn-sm" href="/blog/<%= blog._id %>">Open</a>
                  <% if (locals.user && String(blog.createdBy?._id) === String(user._id)) { %>
                    <form action="/blog/<%= blog._id %>/delete" method="post" onsubmit="return confirm('Delete this blog?');">
                      <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                    </form>
                  <% } %>
                </div>
              </article>
            <% }) %>
          <% } else if (!latestBlog) { %>
            <div class="panel p-4 text-center">
              <h5 class="mb-1">No posts found</h5>
              <p class="theme-text-muted mb-0">Try a different category or search keyword.</p>
            </div>
          <% } %>
        </section>

        <aside class="col-lg-4">
          <div class="panel p-4 mb-3">
            <h5 class="fw-bold mb-3">Trending now</h5>
            <% if (trendingBlogs.length > 0) { %>
              <% trendingBlogs.forEach((post, idx) => { %>
                <div class="trending-item">
                  <div class="small theme-text-muted">#<%= idx + 1 %> in blogs</div>
                  <a href="/blog/<%= post._id %>" class="fw-semibold text-decoration-none" style="color: var(--text-main);"><%= post.title %></a>
                  <div class="small theme-text-muted"><%= post.category || 'Others' %> • Likes <%= post.likesCount || 0 %></div>
                </div>
              <% }) %>
            <% } else { %>
              <p class="theme-text-muted mb-0">No trending posts yet.</p>
            <% } %>
          </div>

          <div class="panel p-4 mb-3">
            <h5 class="fw-bold mb-3">Who to follow</h5>
            <% if (suggestedUsers.length > 0) { %>
              <% suggestedUsers.forEach((person) => { %>
                <div class="user-row">
                  <a href="/user/profile/<%= person._id %>" class="text-decoration-none d-flex align-items-center gap-2">
                    <img src="<%= person.profileImageURL || '/images/default.jpg' %>" width="38" height="38" class="rounded-circle border" alt="">
                    <div>
                      <div class="fw-semibold" style="color: var(--text-main);"><%= person.fullName %></div>
                      <div class="small theme-text-muted"><%= person.followers?.length || 0 %> followers</div>
                    </div>
                  </a>
                  <% if (locals.user) { %>
                    <% const isFollowed = currentUserFollowingIds.includes(String(person._id)); %>
                    <form method="post" action="/user/<%= person._id %>/follow" class="m-0">
                      <input type="hidden" name="redirectTo" value="<%= currentPath %>">
                      <button class="btn btn-sm <%= isFollowed ? 'btn-outline-secondary' : 'btn-brand' %>" type="submit"><%= isFollowed ? 'Following' : 'Follow' %></button>
                    </form>
                  <% } %>
                </div>
              <% }) %>
            <% } else { %>
              <p class="theme-text-muted mb-0">No suggestions available.</p>
            <% } %>
          </div>

          <div class="panel p-4">
            <h6 class="fw-bold">Quick actions</h6>
            <p class="theme-text-muted small">Publish a new post or open your profile dashboard.</p>
            <div class="d-grid gap-2">
              <a href="/blog/add-new" class="btn btn-brand">Create Post</a>
              <% if (locals.user) { %>
                <a href="/user/me" class="btn btn-outline-primary">My Profile</a>
              <% } else { %>
                <a href="/user/signin" class="btn btn-outline-primary">Sign In</a>
              <% } %>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <%- include('./partials/scripts') %>
</body>
</html>
