<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./partials/head') %>
  <title>Create New Post | Blog</title>
  <style>
    body {
      background-color: var(--bg-main);
      color: var(--text-main);
    }

    .form-container {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: 20px;
      box-shadow: 0 10px 25px var(--shadow-color);
      padding: 40px;
      margin-top: 50px;
      max-width: 800px;
    }

    .form-label {
      font-weight: 600;
      color: var(--text-main);
      margin-bottom: 8px;
    }

    .form-control {
      border-radius: 10px;
      padding: 12px;
      border: 1px solid var(--border-color);
      transition: all 0.3s ease;
      background: var(--bg-subtle);
      color: var(--text-main);
    }

    .form-control:focus, .form-select:focus {
      border-color: var(--brand);
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--brand) 25%, transparent);
    }

    textarea.form-control {
      min-height: 200px;
    }

    .form-select {
      border-radius: 10px;
      padding: 12px;
      border: 1px solid var(--border-color);
      background: var(--bg-subtle);
      color: var(--text-main);
    }

    .btn-submit {
      background-color: var(--brand);
      border: none;
      padding: 12px 30px;
      border-radius: 10px;
      font-weight: 600;
      letter-spacing: 0.5px;
      transition: background 0.3s;
    }

    .btn-submit:hover {
      background-color: var(--brand-hover);
    }

    .page-title {
      font-weight: 800;
      color: var(--text-main);
      margin-bottom: 30px;
    }
  </style>
</head>

<body>
  <%- include('./partials/nav') %>

  <div class="container d-flex justify-content-center">
    <div class="form-container w-100">
      <h2 class="page-title text-center">Write a <span style="color: var(--brand);">New Story</span></h2>

      <form action="/blog" method="post" enctype="multipart/form-data">
        
        <div class="mb-4">
          <label for="coverImage" class="form-label">Cover Image</label>
          <input type="file" class="form-control" id="coverImage" name="coverImage" accept="image/*" required />
          <div class="form-text">Choose a high-quality landscape image.</div>
        </div>

        <div class="mb-4">
          <label for="title" class="form-label">Blog Title</label>
          <input type="text" class="form-control" id="title" name="title" placeholder="Enter a catchy title..." required>
        </div>

        <div class="mb-4">
          <label for="category" class="form-label">Category</label>
          <select class="form-select" id="category" name="category" required>
            <% const availableCategories = locals.categories || ["Technology", "Programming", "Web Development", "Mobile Apps", "Artificial Intelligence", "Cyber Security", "Career & Interviews", "Tutorials", "Lifestyle", "Travel", "Health & Fitness", "Finance", "Education", "Sports", "Movies", "Short Stories", "Poetry", "Personal Experiences", "Motivation", "Book Reviews", "History", "Science", "Entertainment", "Others"]; %>
            <% availableCategories.forEach((category) => { %>
              <option value="<%= category %>"><%= category %></option>
            <% }) %>
          </select>
        </div>

        <div class="mb-4">
          <label for="body" class="form-label">Content</label>
          <textarea name="body" class="form-control" id="body" placeholder="Start writing your thoughts here..." required></textarea>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary btn-submit">Publish Blog</button>
        </div>

      </form>
    </div>
  </div>

  <%- include('./partials/scripts') %>
</body>

</html>
