<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
    <title>Sign In | Welcome Back</title>
    <style>
        body {
            background: radial-gradient(circle at top right, color-mix(in srgb, var(--brand) 20%, transparent), transparent 50%), var(--bg-main);
            min-height: 100vh;
            color: var(--text-main);
        }

        .auth-card {
            background: color-mix(in srgb, var(--bg-surface) 92%, transparent);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 15px 35px var(--shadow-color);
            padding: 40px;
            margin-top: 80px;
            max-width: 450px;
            border: 1px solid var(--border-color);
        }

        .auth-title {
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 10px;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .form-control {
            border-radius: 12px;
            padding: 12px;
            border: 1px solid var(--border-color);
            transition: all 0.3s ease;
            background: var(--bg-subtle);
            color: var(--text-main);
        }

        .form-control:focus {
            box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand) 25%, transparent);
            border-color: var(--brand);
        }

        .btn-signin {
            background: var(--brand);
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 700;
            width: 100%;
            margin-top: 20px;
            transition: transform 0.2s, background 0.3s;
        }

        .btn-signin:hover {
            background: var(--brand-hover);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px var(--shadow-color);
        }

        .signup-link {
            text-decoration: none;
            color: var(--brand);
            font-weight: 600;
        }
    </style>
</head>

<body>
    <%- include('./partials/nav') %>

    <div class="container d-flex justify-content-center">
        <div class="auth-card w-100">
            <div class="text-center mb-4">
                <h2 class="auth-title">Welcome Back</h2>
                <p class="text-muted">Enter your details to access your account</p>
            </div>

            <form action="/user/signin" method="post">
                <div class="mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" id="email"
                           placeholder="name@example.com" required />
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label for="password" class="form-label">Password</label>
                        <a href="#" class="text-muted small text-decoration-none">Forgot?</a>
                    </div>
                    <input name="password" type="password" class="form-control" id="password"
                           placeholder="********" required />
                </div>

                <button type="submit" class="btn btn-primary btn-signin">Sign In</button>

                <div class="mt-4 text-center">
                    <p class="small text-muted">
                        Don't have an account? <a href="/user/signup" class="signup-link">Create one</a>
                    </p>
                </div>
            </form>
        </div>
    </div>

    <%- include('./partials/scripts') %>
</body>

</html>
