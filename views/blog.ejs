<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title><%= blog.title %> | Blog</title>
  <style>
    .blog-header { max-width: 840px; margin: 60px auto 30px; }
    .blog-title { font-size: clamp(2rem, 5vw, 2.9rem); font-weight: 800; line-height: 1.2; margin-bottom: 18px; }

    .meta-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 24px;
    }

    .meta-pill {
      display: inline-flex;
      align-items: center;
      border: 1px solid var(--border-color);
      border-radius: 999px;
      padding: 0.35rem 0.8rem;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--text-muted);
      background: var(--bg-subtle);
    }

    .author-badge {
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 12px 0;
      margin-bottom: 24px;
      border-top: 1px solid var(--border-color);
      border-bottom: 1px solid var(--border-color);
    }

    .author-img {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      object-fit: cover;
      box-shadow: 0 4px 10px var(--shadow-color);
    }

    .author-details { display: flex; flex-direction: column; }
    .author-name { font-weight: 700; color: var(--brand); font-size: 1.1rem; margin: 0; }
    .post-date { font-size: 0.85rem; color: var(--text-muted); }

    .featured-image {
      width: 100%;
      border-radius: 24px;
      margin-bottom: 34px;
      border: 1px solid var(--border-color);
      box-shadow: 0 20px 40px var(--shadow-color);
      max-height: 430px;
      object-fit: cover;
    }

    .blog-content {
      font-size: 1.1rem;
      line-height: 1.9;
      color: var(--text-main);
      white-space: pre-wrap;
      margin-bottom: 40px;
    }

    .comment-section {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: 24px;
      padding: 35px;
      margin-top: 40px;
    }

    .comment-card {
      border-bottom: 1px solid var(--border-color);
      padding: 20px 0;
    }

    .comment-card:last-child { border-bottom: none; }
  </style>
</head>

<body>
  <%- include('./partials/nav') %>

  <article class="container">
    <div class="blog-header">
      <h1 class="blog-title"><%= blog.title %></h1>

      <div class="meta-pills">
        <span class="meta-pill"><%= blog.category || "Others" %></span>
        <span class="meta-pill">Likes: <%= blog.likesCount || 0 %></span>
        <span class="meta-pill"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
      </div>

      <div class="author-badge">
        <img src="<%= blog.createdBy?.profileImageURL || '/images/default.jpg' %>" class="author-img" alt="Author">
        <div class="author-details">
          <p class="author-name">By <a href="/user/profile/<%= blog.createdBy?._id %>" class="text-decoration-none" style="color: var(--brand);"><%= blog.createdBy?.fullName %></a></p>
          <span class="post-date">Published on <%= new Date(blog.createdAt).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
        </div>
      </div>

      <div class="d-flex flex-wrap gap-2 mb-4">
        <% if (locals.user) { %>
          <form action="/blog/<%= blog._id %>/like" method="post">
            <button type="submit" class="btn <%= hasLiked ? 'btn-outline-secondary' : 'btn-brand' %>">
              <%= hasLiked ? 'Unlike' : 'Like this post' %>
            </button>
          </form>
          <% if (!isOwnAuthor) { %>
            <form action="/user/<%= blog.createdBy?._id %>/follow" method="post">
              <input type="hidden" name="redirectTo" value="/blog/<%= blog._id %>">
              <button type="submit" class="btn <%= isFollowingAuthor ? 'btn-outline-secondary' : 'btn-brand' %>">
                <%= isFollowingAuthor ? 'Following Author' : 'Follow Author' %>
              </button>
            </form>
          <% } %>
        <% } else { %>
          <a class="btn btn-brand" href="/user/signin">Sign in to Like</a>
          <a class="btn btn-outline-primary" href="/user/signin">Sign in to Follow Author</a>
        <% } %>

        <% if (locals.user && blog.createdBy && String(blog.createdBy._id) === String(user._id)) { %>
          <form action="/blog/<%= blog._id %>/delete" method="post" onsubmit="return confirm('Are you sure you want to delete this blog?');">
            <button type="submit" class="btn btn-danger px-4">Delete Blog</button>
          </form>
        <% } %>
      </div>

      <img src="<%= blog.coverImageURL || '/images/default.jpg' %>" class="featured-image" alt="<%= blog.title %>">

      <div class="blog-content"><%= blog.body %></div>

      <div class="p-4 theme-subtle rounded-4 d-flex align-items-center gap-3 mb-5 border">
        <img src="<%= blog.createdBy?.profileImageURL || '/images/default.jpg' %>" width="60" height="60" class="rounded-circle" alt="">
        <div>
          <h6 class="mb-0 fw-bold">About <%= blog.createdBy?.fullName %></h6>
          <p class="mb-0 theme-text-muted small">Content Creator at Blogify</p>
        </div>
      </div>

      <section class="comment-section shadow-sm mb-5">
        <h4 class="fw-bold mb-4">Discussion (<%= comments.length %>)</h4>

        <% if (locals.user) { %>
          <form action="/blog/comment/<%= blog._id %>" method="post" class="mb-5">
            <textarea name="content" class="form-control p-3" rows="3" required placeholder="Join the conversation..." style="border-radius: 15px; background: var(--bg-subtle);"></textarea>
            <div class="text-end mt-2">
              <button class="btn btn-brand px-4 fw-bold" type="submit" style="border-radius: 50px;">Post Comment</button>
            </div>
          </form>
        <% } %>

        <div class="comment-list">
          <% comments.forEach(comment => { %>
            <div class="comment-card">
              <div class="d-flex align-items-center gap-2 mb-2">
                <img src="<%= comment.createdBy?.profileImageURL || '/images/default.jpg' %>" class="rounded-circle" width="30" height="30" alt="">
                <span class="fw-bold small"><%= comment.createdBy?.fullName %></span>
              </div>
              <p class="theme-text-muted mb-0 ps-4 ms-2 border-start"><%= comment.content %></p>
            </div>
          <% }) %>
        </div>
      </section>
    </div>
  </article>

  <%- include('./partials/scripts') %>
</body>
</html>
